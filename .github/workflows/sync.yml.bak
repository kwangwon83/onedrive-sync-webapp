name: OneDrive to GitHub Sync

on:
  schedule:
    - cron: '0 * * * *'  # 매시간 정각에 자동으로 실행하옵니다.
  workflow_dispatch:      # 전하께서 원하실 때 언제든 수동으로 실행 가능하옵니다.

# 파발마에게 창고를 수정할 수 있는 권한을 하사하옵니다.
permissions:
  contents: write

# 구형 수레바퀴(Node 20) 경고를 잠재우는 설정이옵니다.
env:
  FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: true

jobs:
  sync:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout Repository
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.10'

      - name: Install Dependencies
        run: pip install requests msal

      - name: Run Sync Script
        env:
          AZURE_CLIENT_ID: ${{ secrets.AZURE_CLIENT_ID }}
          AZURE_CLIENT_SECRET: ${{ secrets.AZURE_CLIENT_SECRET }}
          AZURE_TENANT_ID: ${{ secrets.AZURE_TENANT_ID }}
        run: python sync.py

      - name: Commit and Push Changes
        run: |
          git config --global user.name "github-actions[bot]"
          git config --global user.email "github-actions[bot]@users.noreply.github.com"
          git add content/  # 오직 content 폴더의 변화만 기록하옵니다.
          
          if git diff-index --quiet HEAD --; then
            echo "새로 징발할 지식이 없어 작업을 마칩니다."
          else
            git commit -m "Auto-sync from OneDrive to content folder"
            git push
          fi
